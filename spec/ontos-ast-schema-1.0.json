{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ontos-protocol.org/schema/ontos-ast-1.0.json",
  "title": ".ontos AST Schema 1.0",
  "description": "Canonical AST schema for .ontos Format 1.0 documents.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "formatVersion", "metadata", "nodes"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0"
    },
    "formatVersion": {
      "type": "string",
      "const": "1.0"
    },
    "metadata": {
      "$ref": "#/$defs/metadata"
    },
    "nodes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/diagnostic"
      }
    },
    "comments": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/comment"
      }
    }
  },
  "$defs": {
    "metadata": {
      "type": "object",
      "additionalProperties": {
        "type": ["string", "number", "boolean", "null"]
      },
      "required": ["title"],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "updated": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "id": {
          "$ref": "#/$defs/id"
        },
        "schema": {
          "type": "string"
        },
        "lang": {
          "type": "string"
        }
      }
    },
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "tags", "fields", "children"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "tags": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/tag"
          },
          "uniqueItems": true
        },
        "fields": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/fieldValue"
          }
        },
        "children": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/node"
          }
        },
        "references": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/reference"
          }
        },
        "source": {
          "$ref": "#/$defs/sourceRange"
        }
      }
    },
    "fieldValue": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "boolean"
        },
        {
          "type": "null"
        },
        {
          "type": "array",
          "items": {
            "type": ["string", "number", "boolean", "null"]
          }
        },
        {
          "$ref": "#/$defs/richField"
        }
      ]
    },
    "richField": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "value"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["text", "list", "code", "reference", "object"]
        },
        "value": {},
        "language": {
          "type": "string"
        },
        "source": {
          "$ref": "#/$defs/sourceRange"
        }
      }
    },
    "reference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "target"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["node", "field", "file", "url"]
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "$ref": "#/$defs/sourceRange"
        }
      }
    },
    "diagnostic": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "severity", "message"],
      "properties": {
        "code": {
          "type": "string",
          "pattern": "^ONTOS[0-9]{4}$"
        },
        "severity": {
          "type": "string",
          "enum": ["error", "warning", "info"]
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "$ref": "#/$defs/sourceRange"
        },
        "nodeId": {
          "$ref": "#/$defs/id"
        },
        "field": {
          "type": "string"
        },
        "suggestion": {
          "type": "string"
        }
      }
    },
    "comment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "source"],
      "properties": {
        "text": {
          "type": "string"
        },
        "source": {
          "$ref": "#/$defs/sourceRange"
        }
      }
    },
    "sourceRange": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start", "end"],
      "properties": {
        "start": {
          "$ref": "#/$defs/sourcePosition"
        },
        "end": {
          "$ref": "#/$defs/sourcePosition"
        }
      }
    },
    "sourcePosition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["line", "column"],
      "properties": {
        "line": {
          "type": "integer",
          "minimum": 1
        },
        "column": {
          "type": "integer",
          "minimum": 1
        },
        "offset": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "tag": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    }
  }
}

